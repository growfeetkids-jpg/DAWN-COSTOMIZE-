{%- comment -%}
  Section: features.liquid
  Recrée le mécanisme "FIT & TECHNOLOGIES" observé chez le concurrent —
  icônes + libellés courts, implémentation et copy 100% originales.
{%- endcomment -%}

<section class="qt-features qt-section">
  <div class="qt-container">
    <h2 class="qt-features__title">{{ section.settings.title | default: 'Pourquoi Quietta' }}</h2>

    <div class="qt-grid qt-grid--4">
      {% for block in section.blocks %}
        <div class="qt-feature" {{ block.shopify_attributes }}>
          <div class="qt-feature__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.4"/>
              <path d="M8 12l3 3 5-6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="qt-feature__label">{{ block.settings.label }}</h3>
          <p class="qt-feature__desc">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
.qt-features__title {
  text-align: center;
  margin-bottom: 40px;
}
.qt-feature {
  text-align: center;
  padding: 24px 16px;
}
.qt-feature__icon {
  color: var(--qt-terracotta);
  display: flex;
  justify-content: center;
  margin-bottom: 14px;
}
.qt-feature__label {
  font-size: 1rem;
  margin-bottom: 6px;
}
.qt-feature__desc {
  font-size: 0.85rem;
  margin: 0;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Technologies & Confort",
  "settings": [
    { "type": "text", "id": "title", "label": "Titre", "default": "Pourquoi Quietta" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Caractéristique",
      "settings": [
        { "type": "text", "id": "label", "label": "Libellé" },
        { "type": "textarea", "id": "description", "label": "Description courte" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Technologies & Confort",
      "blocks": [
        { "type": "feature", "settings": { "label": "Vraie pointure", "description": "Coupe fidèle à la taille, vérifiée par nos guides." } },
        { "type": "feature", "settings": { "label": "Mesh respirant", "description": "Une tige technique qui laisse respirer le pied toute la journée." } },
        { "type": "feature", "settings": { "label": "Semelle mémoire", "description": "Une mousse qui épouse la forme du pied à chaque pas." } },
        { "type": "feature", "settings": { "label": "Quietta Grip™", "description": "Une semelle texturée conçue pour les sols difficiles." } }
      ]
    }
  ]
}
{% endschema %}
