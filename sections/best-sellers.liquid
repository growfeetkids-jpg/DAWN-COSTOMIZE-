{%- comment -%}
  Section: best-sellers.liquid
  Grille de produits mis en avant — tirés d'une collection choisie dans le customizer.
{%- endcomment -%}

<section class="qt-section qt-best-sellers">
  <div class="qt-container">
    <div class="qt-best-sellers__header">
      <h2>{{ section.settings.title | default: 'Nos best-sellers' }}</h2>
      <a href="{{ section.settings.view_all_url | default: '/collections/all' }}" class="qt-best-sellers__link">
        Voir tout →
      </a>
    </div>

    <div class="qt-grid qt-grid--4">
      {% assign featured = section.settings.collection.products | default: collections.all.products %}
      {% assign pexels_ids = "4046109,1240892,1464453,2003134" | split: "," %}
      {% for product in featured limit: section.settings.products_count %}
        {%- assign pid = pexels_ids[forloop.index0] | default: "2529148" -%}
        <a href="{{ product.url }}" class="qt-product-card">
          <div class="qt-product-card__media">
            {% if product.featured_image %}
              <img src="{{ product.featured_image | image_url: width: 600 }}"
                   alt="{{ product.title }}" loading="lazy" class="qt-product-card__img" width="600" height="800">
            {% else %}
              <img src="https://images.pexels.com/photos/{{ pid }}/pexels-photo-{{ pid }}.jpeg?auto=compress&cs=tinysrgb&w=600"
                   alt="{{ product.title }}" loading="lazy" class="qt-product-card__img" width="600" height="800">
            {% endif %}
          </div>
          {% if product.compare_at_price > product.price %}
            <span class="qt-product-card__badge">Promo</span>
          {% endif %}
          <h3 class="qt-product-card__title">{{ product.title }}</h3>
          <div class="qt-product-card__prices">
            {% if product.compare_at_price > product.price %}
              <span class="qt-product-card__price--compare">{{ product.compare_at_price | money }}</span>
            {% endif %}
            <span class="qt-product-card__price">{{ product.price | money }}</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
.qt-best-sellers__header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 32px;
}
.qt-best-sellers__link {
  font-size: 0.88rem;
  color: var(--qt-terracotta);
  font-weight: 600;
}
.qt-product-card {
  display: block;
  position: relative;
}
.qt-product-card__badge {
  position: absolute;
  top: 12px; left: 12px;
  background: var(--qt-terracotta);
  color: var(--qt-white);
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 4px 10px;
  border-radius: 999px;
}
.qt-product-card__media {
  overflow: hidden;
  border-radius: var(--qt-radius-md);
}
.qt-product-card__img {
  width: 100%;
  aspect-ratio: 3/4;
  object-fit: cover;
  display: block;
  transition: transform var(--qt-duration) var(--qt-ease);
}
.qt-product-card:hover .qt-product-card__img {
  transform: scale(1.03);
}
  margin-bottom: 4px;
  font-size: 0.98rem;
}
.qt-product-card__prices {
  display: flex;
  gap: 8px;
  align-items: center;
}
.qt-product-card__price {
  font-size: 0.9rem;
  color: var(--qt-terracotta);
  font-weight: 600;
}
.qt-product-card__price--compare {
  font-size: 0.82rem;
  color: var(--qt-ink-soft);
  text-decoration: line-through;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Best-sellers",
  "settings": [
    { "type": "text", "id": "title", "label": "Titre", "default": "Nos best-sellers" },
    { "type": "collection", "id": "collection", "label": "Collection source" },
    { "type": "range", "id": "products_count", "label": "Nombre de produits", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "url", "id": "view_all_url", "label": "Lien 'Voir tout'" }
  ],
  "presets": [{ "name": "Best-sellers" }]
}
{% endschema %}
