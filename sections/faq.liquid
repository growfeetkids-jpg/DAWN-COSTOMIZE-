{%- comment -%}
  Section: faq.liquid
  FAQ accordion — homepage. Native <details> pour accessibilité et performance.
{%- endcomment -%}

<section class="qt-section qt-faq">
  <div class="qt-container qt-faq__inner">
    <div class="qt-faq__heading">
      <h2>{{ section.settings.title | default: 'Questions fréquentes' }}</h2>
      <p>{{ section.settings.subtitle | default: 'Tout ce que vous voulez savoir avant de commander.' }}</p>
    </div>

    <div class="qt-faq__list">
      {% for block in section.blocks %}
        <details class="qt-faq__item" {{ block.shopify_attributes }}>
          <summary class="qt-faq__question">
            {{ block.settings.question }}
            <span class="qt-faq__icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </summary>
          <div class="qt-faq__answer">
            <p>{{ block.settings.answer }}</p>
          </div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
.qt-faq__inner {
  display: grid;
  grid-template-columns: 1fr 1.6fr;
  gap: 64px;
  align-items: start;
}
.qt-faq__heading p { margin: 12px 0 0; }

.qt-faq__item {
  border-bottom: 1px solid var(--qt-border);
}
.qt-faq__question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  padding-block: 20px;
  font-weight: 600;
  font-size: 1rem;
  color: var(--qt-petrol);
  list-style: none;
  gap: 16px;
}
.qt-faq__question::-webkit-details-marker { display: none; }
.qt-faq__icon {
  flex-shrink: 0;
  transition: transform var(--qt-duration) var(--qt-ease);
  color: var(--qt-terracotta);
}
details[open] .qt-faq__icon { transform: rotate(180deg); }

.qt-faq__answer {
  padding-bottom: 20px;
}
.qt-faq__answer p { margin: 0; font-size: 0.95rem; }

@media (max-width: 749px) {
  .qt-faq__inner { grid-template-columns: 1fr; gap: 32px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "title", "label": "Titre", "default": "Questions fréquentes" },
    { "type": "textarea", "id": "subtitle", "label": "Sous-titre" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Réponse" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "item", "settings": { "question": "Est-ce que la pointure correspond à ma taille habituelle ?", "answer": "Oui, nos modèles taillent normalement. Consultez notre guide des tailles pour vérifier votre correspondance exacte selon votre pays." } },
        { "type": "item", "settings": { "question": "Les chaussures antidérapantes sont-elles vraiment efficaces sur sol gras ?", "answer": "Notre semelle Quietta Grip™ a été testée sur surfaces grasses et humides, typiques des cuisines professionnelles et environnements de restauration." } },
        { "type": "item", "settings": { "question": "Quels sont les délais de livraison ?", "answer": "Les commandes sont expédiées sous 1 à 3 jours ouvrés. Le délai standard est de 3 à 7 jours selon votre localisation." } },
        { "type": "item", "settings": { "question": "Quelle est votre politique de retour ?", "answer": "Vous disposez de 30 jours pour retourner un article non porté, dans son emballage d'origine." } }
      ]
    }
  ]
}
{% endschema %}
