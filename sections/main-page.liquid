{%- comment -%}
  Section: main-page.liquid
{%- endcomment -%}

<section class="qt-section">
  <div class="qt-container qt-page">
    <h1>{{ page.title }}</h1>
    <div class="qt-page__content">
      {{ page.content }}
    </div>
  </div>
</section>

{% stylesheet %}
.qt-page {
  max-width: 760px;
  margin: 0 auto;
}
.qt-page__content {
  font-size: 1rem;
}
{% endstylesheet %}

{% schema %}
{ "name": "Page", "settings": [] }
{% endschema %}
