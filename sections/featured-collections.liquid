{%- comment -%}
  Section: featured-collections.liquid
  Présente les 3 collections clés identifiées en Phase 1-2 :
  Femme / Homme / Anti-Dérapant (segment à forte intention).
{%- endcomment -%}

<section class="qt-collections qt-section">
  <div class="qt-container">
    <div class="qt-grid qt-grid--3">
      {% for block in section.blocks %}
        {%- assign block_index = forloop.index0 -%}
        <a href="{{ block.settings.collection_url }}" class="qt-collection-card" {{ block.shopify_attributes }}>
          {%- if block_index == 0 -%}
            <img src="https://images.pexels.com/photos/2529148/pexels-photo-2529148.jpeg?auto=compress&cs=tinysrgb&w=700"
                 alt="{{ block.settings.title }} — Quietta" loading="lazy" class="qt-collection-card__img" width="700" height="933">
          {%- elsif block_index == 1 -%}
            <img src="https://images.pexels.com/photos/1598505/pexels-photo-1598505.jpeg?auto=compress&cs=tinysrgb&w=700"
                 alt="{{ block.settings.title }} — Quietta" loading="lazy" class="qt-collection-card__img" width="700" height="933">
          {%- else -%}
            <img src="https://images.pexels.com/photos/3680035/pexels-photo-3680035.jpeg?auto=compress&cs=tinysrgb&w=700"
                 alt="{{ block.settings.title }} — Quietta" loading="lazy" class="qt-collection-card__img" width="700" height="933">
          {%- endif -%}
          <h3 class="qt-collection-card__title">{{ block.settings.title }}</h3>
          <span class="qt-collection-card__cta">Découvrir →</span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
.qt-collection-card {
  display: block;
  text-align: left;
}
.qt-collection-card__title {
  margin-top: 16px;
  margin-bottom: 4px;
  font-size: 1.2rem;
}
.qt-collection-card__cta {
  font-size: 0.85rem;
  color: var(--qt-terracotta);
  font-weight: 600;
}
.qt-collection-card__img {
  width: 100%;
  aspect-ratio: 3/4;
  object-fit: cover;
  border-radius: var(--qt-radius-lg);
  display: block;
  transition: transform var(--qt-duration) var(--qt-ease);
}
.qt-collection-card:hover .qt-collection-card__img {
  transform: scale(1.02);
}
{% endstylesheet %}

{% schema %}
{
  "name": "Collections en avant",
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "text", "id": "title", "label": "Titre affiché" },
        { "type": "url", "id": "collection_url", "label": "Lien" },
        { "type": "text", "id": "image_label", "label": "Label du placeholder image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collections en avant",
      "blocks": [
        { "type": "collection", "settings": { "title": "Femme", "image_label": "Lifestyle Femme (à générer)" } },
        { "type": "collection", "settings": { "title": "Homme", "image_label": "Lifestyle Homme (à générer)" } },
        { "type": "collection", "settings": { "title": "Anti-Dérapant", "image_label": "Anti-Dérapant (à générer)" } }
      ]
    }
  ]
}
{% endschema %}
