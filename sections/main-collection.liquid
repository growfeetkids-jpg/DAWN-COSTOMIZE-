{%- comment -%}
  Section: main-collection.liquid
{%- endcomment -%}

<section class="qt-section">
  <div class="qt-container">
    <header class="qt-collection-header">
      <h1>{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <p>{{ collection.description }}</p>
      {% endif %}
    </header>

    <div class="qt-grid qt-grid--4">
      {% for product in collection.products %}
        <a href="{{ product.url }}" class="qt-product-card">
          {% render 'image-placeholder', ratio: '3/4', label: product.title, rounded: true %}
          <h3 class="qt-product-card__title">{{ product.title }}</h3>
          <p class="qt-product-card__price">{{ product.price | money }}</p>
        </a>
      {% else %}
        <p>Aucun produit dans cette collection pour le moment.</p>
      {% endfor %}
    </div>

    {% if paginate.pages > 1 %}
      {{ paginate(collection.products) }}
    {% endif %}
  </div>
</section>

{% stylesheet %}
.qt-collection-header {
  text-align: center;
  max-width: 640px;
  margin: 0 auto 48px;
}
.qt-product-card__title {
  margin-top: 14px;
  margin-bottom: 4px;
  font-size: 1rem;
}
.qt-product-card__price {
  font-size: 0.9rem;
  color: var(--qt-terracotta);
  font-weight: 600;
  margin: 0;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Collection",
  "settings": []
}
{% endschema %}
